<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo_oscuro">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/txtTituloPerfilVisitante"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Visitantes"
            android:textColor="@color/blanco"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginTop="24dp" />

        <LinearLayout
            android:id="@+id/cardPerfilVisitante"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/blanco"
            android:padding="18dp"
            android:layout_marginTop="32dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="54dp"
                    android:layout_height="54dp"
                    android:text="FB"
                    android:textColor="@color/azul_principal"
                    android:textSize="18sp"
                    android:gravity="center"
                    android:background="@color/azul_claro" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Fernando Baca"
                        android:textColor="@color/negro"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Visitante"
                        android:textColor="@color/gris_texto"
                        android:textSize="13sp"
                        android:layout_marginTop="4dp" />

                </LinearLayout>

            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Actividad: Musculación"
                android:textColor="@color/negro"
                android:textSize="13sp"
                android:layout_marginTop="18dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Apto físico: Sí   Fecha: 23/03/26"
                android:textColor="@color/negro"
                android:textSize="13sp"
                android:layout_marginTop="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="fbaca@borcelleclub.com"
                android:textColor="@color/gris_texto"
                android:textSize="12sp"
                android:layout_marginTop="10dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="+54 11 2345-6854"
                android:textColor="@color/gris_texto"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />

            <Button
                android:id="@+id/btnCobrarVisitante"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:text="Cobrar actividad"
                android:textColor="@color/blanco"
                android:textStyle="bold"
                android:backgroundTint="@color/azul_principal"
                android:layout_marginTop="24dp" />

            <Button
                android:id="@+id/btnEditarVisitante"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:text="Editar Perfil"
                android:textColor="@color/blanco"
                android:textStyle="bold"
                android:backgroundTint="@color/azul_claro"
                android:layout_marginTop="10dp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>