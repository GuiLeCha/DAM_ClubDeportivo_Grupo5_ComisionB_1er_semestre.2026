<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo_oscuro">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <Button
            android:id="@+id/btnVolverPerfilSocioSuperior"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="← Volver"
            android:textColor="@color/blanco"
            android:textStyle="bold"
            android:backgroundTint="@color/azul_principal" />

        <TextView
            android:id="@+id/txtTituloPerfilSocio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Socios"
            android:textColor="@color/blanco"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginTop="24dp" />

        <LinearLayout
            android:id="@+id/cardPerfilSocio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/blanco"
            android:padding="18dp"
            android:layout_marginTop="32dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/txtInicialesPerfilSocio"
                    android:layout_width="54dp"
                    android:layout_height="54dp"
                    android:text="SC"
                    android:textColor="@color/azul_principal"
                    android:textSize="18sp"
                    android:gravity="center"
                    android:background="@color/azul_claro" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">

                    <TextView
                        android:id="@+id/txtNombrePerfilSocio"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nombre del socio"
                        android:textColor="@color/negro"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txtNumeroPerfilSocio"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="N° de socio"
                        android:textColor="@color/negro"
                        android:textSize="13sp"
                        android:layout_marginTop="4dp" />

                </LinearLayout>

            </LinearLayout>

            <TextView
                android:id="@+id/txtCuotaPerfilSocio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Vencimiento cuota"
                android:textColor="@color/rojo_alerta"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginTop="18dp" />

            <TextView
                android:id="@+id/txtEstadoPerfilSocio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Estado"
                android:textColor="@color/rojo_alerta"
                android:textSize="13sp"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/txtDniPerfilSocio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="DNI"
                android:textColor="@color/gris_texto"
                android:textSize="12sp"
                android:layout_marginTop="10dp" />

            <TextView
                android:id="@+id/txtEmailPerfilSocio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Email"
                android:textColor="@color/gris_texto"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/txtTelefonoPerfilSocio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Teléfono"
                android:textColor="@color/gris_texto"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/txtDireccionPerfilSocio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Dirección"
                android:textColor="@color/gris_texto"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/txtAptoPerfilSocio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Apto físico"
                android:textColor="@color/gris_texto"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />

            <Button
                android:id="@+id/btnCobrarSocio"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:text="Cobrar"
                android:textColor="@color/blanco"
                android:textStyle="bold"
                android:backgroundTint="@color/azul_principal"
                android:layout_marginTop="24dp" />

            <Button
                android:id="@+id/btnEditarSocio"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:text="Editar Perfil"
                android:textColor="@color/blanco"
                android:textStyle="bold"
                android:backgroundTint="@color/azul_claro"
                android:layout_marginTop="10dp" />

            <Button
                android:id="@+id/btnEmitirCarnet"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:text="Emitir Carnet"
                android:textColor="@color/blanco"
                android:textStyle="bold"
                android:backgroundTint="@color/azul_principal"
                android:layout_marginTop="10dp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>