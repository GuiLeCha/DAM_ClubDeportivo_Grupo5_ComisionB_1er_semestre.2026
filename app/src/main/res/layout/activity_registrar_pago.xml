<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo_oscuro">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/txtTituloRegistrarPago"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Registrar pago"
            android:textColor="@color/blanco"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginTop="24dp" />

        <LinearLayout
            android:id="@+id/cardDatosPago"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/blanco"
            android:padding="18dp"
            android:layout_marginTop="28dp">

            <TextView
                android:id="@+id/txtClientePago"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Julia Piassentini"
                android:textColor="@color/negro"
                android:textSize="21sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtDetalleClientePago"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Socio N° 23721"
                android:textColor="@color/gris_texto"
                android:textSize="13sp"
                android:layout_marginTop="6dp" />

            <TextView
                android:id="@+id/txtConceptoPago"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Concepto"
                android:textColor="@color/negro"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginTop="24dp" />

            <EditText
                android:id="@+id/edtConceptoPago"
                android:layout_width="match_parent"
                android:layout_height="38dp"
                android:hint="Cuota mensual"
                android:inputType="text"
                android:textColor="@color/negro"
                android:textColorHint="@color/gris_medio"
                android:background="@color/fondo_claro"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:layout_marginTop="8dp" />

            <TextView
                android:id="@+id/txtMontoPago"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Monto"
                android:textColor="@color/negro"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp" />

            <EditText
                android:id="@+id/edtMontoPago"
                android:layout_width="match_parent"
                android:layout_height="38dp"
                android:hint="$ 12.000"
                android:inputType="number"
                android:textColor="@color/negro"
                android:textColorHint="@color/gris_medio"
                android:background="@color/fondo_claro"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:layout_marginTop="8dp" />

            <TextView
                android:id="@+id/txtMedioPago"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Medio de pago"
                android:textColor="@color/negro"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginTop="18dp" />

            <CheckBox
                android:id="@+id/chkEfectivo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Efectivo"
                android:textColor="@color/negro"
                android:textSize="13sp"
                android:layout_marginTop="6dp" />

            <CheckBox
                android:id="@+id/chkTarjeta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tarjeta de crédito"
                android:textColor="@color/negro"
                android:textSize="13sp" />

            <CheckBox
                android:id="@+id/chkTransferencia"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Transferencia"
                android:textColor="@color/negro"
                android:textSize="13sp" />

        </LinearLayout>

        <Button
            android:id="@+id/btnRegistrarPago"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:text="Registrar Pago"
            android:textColor="@color/blanco"
            android:textStyle="bold"
            android:backgroundTint="@color/azul_principal"
            android:layout_marginTop="30dp" />

    </LinearLayout>

</ScrollView>