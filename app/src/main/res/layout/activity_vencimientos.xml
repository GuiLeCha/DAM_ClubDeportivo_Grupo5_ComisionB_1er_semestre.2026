<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo_oscuro">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="22dp">

        <LinearLayout
            android:id="@+id/headerVencimientos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="18dp">

            <ImageView
                android:id="@+id/imgIconoVencimientos"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@android:drawable/ic_dialog_alert"
                android:contentDescription="Vencimientos" />

            <TextView
                android:id="@+id/txtTituloVencimientos"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Vencimientos"
                android:textColor="@color/blanco"
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_marginStart="8dp" />

            <TextView
                android:id="@+id/txtMenuVencimientos"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="☰"
                android:textColor="@color/blanco"
                android:textSize="26sp" />

        </LinearLayout>

        <TextView
            android:id="@+id/txtSubtituloVencimientos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Control visual de cuotas vencidas o próximas a vencer"
            android:textColor="@color/gris_medio"
            android:textSize="14sp"
            android:layout_marginTop="16dp" />

        <LinearLayout
            android:id="@+id/cardVencimientoJulia"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/blanco"
            android:padding="14dp"
            android:layout_marginTop="20dp">

            <TextView
                android:id="@+id/txtNombreJuliaVencimiento"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Julia Piassentini"
                android:textColor="@color/negro"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtSocioJuliaVencimiento"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Socio N° 23721"
                android:textColor="@color/gris_texto"
                android:textSize="13sp"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/txtCuotaJuliaVencimiento"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Cuota vencida: 15/03/26"
                android:textColor="@color/rojo_alerta"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp" />

            <TextView
                android:id="@+id/txtEstadoJuliaVencimiento"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Estado: En mora"
                android:textColor="@color/rojo_alerta"
                android:textSize="13sp"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/txtContactoJuliaVencimiento"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="jpiassentini@borcelleclub.com  ·  +54 11 2345-6821"
                android:textColor="@color/gris_texto"
                android:textSize="12sp"
                android:layout_marginTop="8dp" />

            <Button
                android:id="@+id/btnNotificarJulia"
                android:layout_width="130dp"
                android:layout_height="38dp"
                android:text="Notificar"
                android:textColor="@color/blanco"
                android:textSize="12sp"
                android:backgroundTint="@color/azul_principal"
                android:layout_gravity="end"
                android:layout_marginTop="12dp" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/cardVencimientoMariana"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/blanco"
            android:padding="14dp"
            android:layout_marginTop="18dp">

            <TextView
                android:id="@+id/txtNombreMarianaVencimiento"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Mariana Borda"
                android:textColor="@color/negro"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtSocioMarianaVencimiento"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Socio N° 24540"
                android:textColor="@color/gris_texto"
                android:textSize="13sp"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/txtCuotaMarianaVencimiento"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Cuota próxima a vencer: 30/03/26"
                android:textColor="@color/azul_principal"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp" />

            <TextView
                android:id="@+id/txtEstadoMarianaVencimiento"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Estado: Pendiente de seguimiento"
                android:textColor="@color/gris_texto"
                android:textSize="13sp"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/txtContactoMarianaVencimiento"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="mborda@borcelleclub.com  ·  +54 11 2345-6843"
                android:textColor="@color/gris_texto"
                android:textSize="12sp"
                android:layout_marginTop="8dp" />

            <Button
                android:id="@+id/btnNotificarMariana"
                android:layout_width="130dp"
                android:layout_height="38dp"
                android:text="Notificar"
                android:textColor="@color/blanco"
                android:textSize="12sp"
                android:backgroundTint="@color/azul_principal"
                android:layout_gravity="end"
                android:layout_marginTop="12dp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>