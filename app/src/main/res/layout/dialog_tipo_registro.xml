<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/dialogTipoRegistro"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/blanco"
    android:padding="22dp">

    <TextView
        android:id="@+id/txtCerrarRegistro"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="X"
        android:textColor="@color/gris_medio"
        android:textSize="16sp"
        android:gravity="end" />

    <TextView
        android:id="@+id/txtPreguntaRegistro"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="¿QUÉ TIPO DE CLIENTE QUERÉS REGISTRAR?"
        android:textColor="@color/gris_texto"
        android:textSize="12sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginTop="22dp" />

    <LinearLayout
        android:id="@+id/contenedorCardsRegistro"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="28dp">

        <LinearLayout
            android:id="@+id/cardSocioRegistro"
            android:layout_width="105dp"
            android:layout_height="105dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@color/fondo_claro"
            android:padding="10dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/imgSocioRegistro"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:src="@android:drawable/ic_menu_myplaces"
                android:contentDescription="Socio" />

            <TextView
                android:id="@+id/txtSocioRegistro"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SOCIO"
                android:textColor="@color/azul_principal"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/cardVisitanteRegistro"
            android:layout_width="105dp"
            android:layout_height="105dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@color/fondo_claro"
            android:padding="10dp"
            android:layout_marginStart="16dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/imgVisitanteRegistro"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:src="@android:drawable/ic_menu_add"
                android:contentDescription="Visitante" />

            <TextView
                android:id="@+id/txtVisitanteRegistro"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="VISITANTE"
                android:textColor="@color/azul_principal"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp" />

        </LinearLayout>

    </LinearLayout>

    <Button
        android:id="@+id/btnContinuarRegistroDialog"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:text="CONTINUAR"
        android:textColor="@color/blanco"
        android:textStyle="bold"
        android:backgroundTint="@color/azul_principal"
        android:layout_marginTop="34dp" />

</LinearLayout>