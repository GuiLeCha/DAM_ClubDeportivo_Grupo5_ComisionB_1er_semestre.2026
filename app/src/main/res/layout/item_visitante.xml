<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/cardItemVisitante"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/blanco"
    android:padding="14dp"
    android:layout_marginBottom="18dp">

    <LinearLayout
        android:id="@+id/filaSuperiorItemVisitante"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/txtInicialesItemVisitante"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:text="VC"
            android:textColor="@color/azul_principal"
            android:textSize="17sp"
            android:textStyle="bold"
            android:gravity="center"
            android:background="@color/azul_claro" />

        <LinearLayout
            android:id="@+id/contenedorDatosItemVisitante"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/txtNombreItemVisitante"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nombre del visitante"
                android:textColor="@color/negro"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtDniItemVisitante"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Visitante - DNI"
                android:textColor="@color/gris_texto"
                android:textSize="13sp" />

        </LinearLayout>

    </LinearLayout>

    <TextView
        android:id="@+id/txtActividadItemVisitante"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Actividad"
        android:textColor="@color/gris_texto"
        android:textSize="13sp"
        android:layout_marginTop="12dp" />

    <TextView
        android:id="@+id/txtContactoItemVisitante"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Contacto"
        android:textColor="@color/gris_texto"
        android:textSize="13sp"
        android:layout_marginTop="4dp" />

    <LinearLayout
        android:id="@+id/filaBotonesItemVisitante"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:layout_marginTop="10dp">

        <Button
            android:id="@+id/btnPerfilItemVisitante"
            android:layout_width="130dp"
            android:layout_height="40dp"
            android:text="Ver Perfil"
            android:textColor="@color/blanco"
            android:textSize="12sp"
            android:backgroundTint="@color/azul_principal"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btnBajaItemVisitante"
            android:layout_width="130dp"
            android:layout_height="40dp"
            android:text="Dar de baja"
            android:textColor="@color/blanco"
            android:textSize="12sp"
            android:backgroundTint="@color/rojo_alerta" />

    </LinearLayout>

</LinearLayout>