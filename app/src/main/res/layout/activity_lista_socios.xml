<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo_oscuro">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="22dp">

        <Button
            android:id="@+id/btnVolverListaSocios"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="← Volver"
            android:textColor="@color/blanco"
            android:textStyle="bold"
            android:backgroundTint="@color/azul_principal" />

        <LinearLayout
            android:id="@+id/headerListaSocios"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="18dp">

            <ImageView
                android:id="@+id/imgIconoListaSocios"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@android:drawable/ic_menu_myplaces"
                android:contentDescription="Socios" />

            <TextView
                android:id="@+id/txtTituloListaSocios"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Socios"
                android:textColor="@color/blanco"
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_marginStart="8dp" />

            <TextView
                android:id="@+id/txtMenuListaSocios"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="☰"
                android:textColor="@color/blanco"
                android:textSize="26sp" />

        </LinearLayout>

        <EditText
            android:id="@+id/edtBuscarSocios"
            android:layout_width="match_parent"
            android:layout_height="38dp"
            android:hint="Buscar socios..."
            android:inputType="text"
            android:textColor="@color/negro"
            android:textColorHint="@color/gris_medio"
            android:background="@color/blanco"
            android:drawableStart="@android:drawable/ic_menu_search"
            android:drawablePadding="8dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:layout_marginTop="18dp" />

        <LinearLayout
            android:id="@+id/cardGuillermo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/blanco"
            android:padding="14dp"
            android:layout_marginTop="18dp"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:text="GC"
                    android:textColor="@color/azul_principal"
                    android:textSize="16sp"
                    android:gravity="center"
                    android:background="@color/azul_claro" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Guillermo Chacon"
                    android:textColor="@color/negro"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:layout_marginStart="10dp" />

            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="N° de socio: 23011"
                android:textColor="@color/negro"
                android:textSize="13sp"
                android:layout_marginTop="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Apto: Sí   Vto: 23/03/26"
                android:textColor="@color/negro"
                android:textSize="13sp"
                android:layout_marginTop="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="✉ gchacon@borcelleclub.com"
                android:textColor="@color/gris_texto"
                android:textSize="12sp"
                android:layout_marginTop="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="☎ +54 11 2345-6810"
                android:textColor="@color/gris_texto"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />

            <Button
                android:id="@+id/btnPerfilGuillermo"
                android:layout_width="120dp"
                android:layout_height="38dp"
                android:text="Ver Perfil"
                android:textColor="@color/blanco"
                android:textSize="12sp"
                android:backgroundTint="@color/azul_principal"
                android:layout_gravity="end"
                android:layout_marginTop="10dp" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/cardJulia"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/blanco"
            android:padding="14dp"
            android:layout_marginTop="18dp"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:text="JP"
                    android:textColor="@color/azul_principal"
                    android:textSize="16sp"
                    android:gravity="center"
                    android:background="@color/azul_claro" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Julia Piassentini"
                    android:textColor="@color/negro"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:layout_marginStart="10dp" />

            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="N° de socio: 23721"
                android:textColor="@color/negro"
                android:textSize="13sp"
                android:layout_marginTop="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Apto: Sí   Vto: 15/03/26"
                android:textColor="@color/negro"
                android:textSize="13sp"
                android:layout_marginTop="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="● En mora"
                android:textColor="@color/rojo_alerta"
                android:textSize="13sp"
                android:layout_marginTop="8dp" />

            <Button
                android:id="@+id/btnPerfilJulia"
                android:layout_width="120dp"
                android:layout_height="38dp"
                android:text="Ver Perfil"
                android:textColor="@color/blanco"
                android:textSize="12sp"
                android:backgroundTint="@color/azul_principal"
                android:layout_gravity="end"
                android:layout_marginTop="10dp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>