<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/contenedorPantallaListaSocios"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/fondo_oscuro"
    android:padding="22dp">

    <Button
        android:id="@+id/btnVolverListaSocios"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:text="← Volver"
        android:textColor="@color/blanco"
        android:textStyle="bold"
        android:backgroundTint="@color/azul_principal" />

    <LinearLayout
        android:id="@+id/headerListaSocios"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="18dp">

        <ImageView
            android:id="@+id/imgIconoListaSocios"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:src="@android:drawable/ic_menu_myplaces"
            android:contentDescription="Lista de socios" />

        <TextView
            android:id="@+id/txtTituloListaSocios"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Socios"
            android:textColor="@color/blanco"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginStart="8dp" />

        <TextView
            android:id="@+id/txtMenuListaSocios"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="☰"
            android:textColor="@color/blanco"
            android:textSize="26sp" />

    </LinearLayout>

    <EditText
        android:id="@+id/edtBuscarSocios"
        android:layout_width="match_parent"
        android:layout_height="46dp"
        android:hint="Buscar por nombre, apellido o DNI..."
        android:textColor="@color/negro"
        android:textColorHint="@color/gris_medio"
        android:background="@color/blanco"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:layout_marginTop="22dp"
        android:inputType="text" />

    <LinearLayout
        android:id="@+id/filaBotonesBusquedaSocios"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="10dp">

        <Button
            android:id="@+id/btnBuscarSocios"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:text="Buscar"
            android:textColor="@color/blanco"
            android:textStyle="bold"
            android:backgroundTint="@color/azul_principal" />

        <Button
            android:id="@+id/btnLimpiarBusquedaSocios"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:text="Limpiar"
            android:textColor="@color/blanco"
            android:textStyle="bold"
            android:backgroundTint="@color/azul_claro"
            android:layout_marginStart="10dp" />

    </LinearLayout>

    <TextView
        android:id="@+id/txtEstadoListaSocios"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="@color/gris_medio"
        android:textSize="14sp"
        android:layout_marginTop="16dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerSocios"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="14dp" />

</LinearLayout>