<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo_oscuro">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="22dp">

        <Button
            android:id="@+id/btnVolverUsuarios"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="← Volver"
            android:textColor="@color/blanco"
            android:textStyle="bold"
            android:backgroundTint="@color/azul_principal" />

        <LinearLayout
            android:id="@+id/headerUsuarios"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="18dp">

            <ImageView
                android:id="@+id/imgIconoUsuarios"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@android:drawable/ic_menu_manage"
                android:contentDescription="Usuarios" />

            <TextView
                android:id="@+id/txtTituloUsuarios"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Usuarios"
                android:textColor="@color/blanco"
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_marginStart="8dp" />

            <TextView
                android:id="@+id/txtMenuUsuarios"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="☰"
                android:textColor="@color/blanco"
                android:textSize="26sp" />

        </LinearLayout>

        <TextView
            android:id="@+id/txtSubtituloUsuarios"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Pantalla visual de administración de usuarios"
            android:textColor="@color/gris_medio"
            android:textSize="14sp"
            android:layout_marginTop="16dp" />

        <Button
            android:id="@+id/btnRegistrarUsuario"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:text="REGISTRAR USUARIO"
            android:textColor="@color/azul_principal"
            android:textStyle="bold"
            android:backgroundTint="@color/blanco"
            android:layout_marginTop="24dp" />

        <LinearLayout
            android:id="@+id/cardUsuarioKevin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/blanco"
            android:padding="14dp"
            android:layout_marginTop="22dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:text="KD"
                    android:textColor="@color/azul_principal"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:background="@color/azul_claro" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Kevin Del Bello"
                        android:textColor="@color/negro"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Administrador"
                        android:textColor="@color/gris_texto"
                        android:textSize="13sp"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Acceso general al sistema"
                android:textColor="@color/gris_texto"
                android:textSize="13sp"
                android:layout_marginTop="12dp" />

            <Button
                android:id="@+id/btnVerKevin"
                android:layout_width="130dp"
                android:layout_height="38dp"
                android:text="Ver Perfil"
                android:textColor="@color/blanco"
                android:textSize="12sp"
                android:backgroundTint="@color/azul_principal"
                android:layout_gravity="end"
                android:layout_marginTop="10dp" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/cardUsuarioEric"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/blanco"
            android:padding="14dp"
            android:layout_marginTop="18dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:text="EB"
                    android:textColor="@color/azul_principal"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:background="@color/azul_claro" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Eric Bermudez"
                        android:textColor="@color/negro"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Administración"
                        android:textColor="@color/gris_texto"
                        android:textSize="13sp"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Gestión de socios y vencimientos"
                android:textColor="@color/gris_texto"
                android:textSize="13sp"
                android:layout_marginTop="12dp" />

            <Button
                android:id="@+id/btnBajaEric"
                android:layout_width="130dp"
                android:layout_height="38dp"
                android:text="Dar de baja"
                android:textColor="@color/blanco"
                android:textSize="12sp"
                android:backgroundTint="@color/rojo_alerta"
                android:layout_gravity="end"
                android:layout_marginTop="10dp" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/cardUsuarioFernando"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/blanco"
            android:padding="14dp"
            android:layout_marginTop="18dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:text="FB"
                    android:textColor="@color/azul_principal"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:background="@color/azul_claro" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Fernando Baca"
                        android:textColor="@color/negro"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Caja"
                        android:textColor="@color/gris_texto"
                        android:textSize="13sp"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Registro visual de pagos y comprobantes"
                android:textColor="@color/gris_texto"
                android:textSize="13sp"
                android:layout_marginTop="12dp" />

            <Button
                android:id="@+id/btnBajaFernando"
                android:layout_width="130dp"
                android:layout_height="38dp"
                android:text="Dar de baja"
                android:textColor="@color/blanco"
                android:textSize="12sp"
                android:backgroundTint="@color/rojo_alerta"
                android:layout_gravity="end"
                android:layout_marginTop="10dp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>