<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo_oscuro">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="28dp">

        <LinearLayout
            android:id="@+id/cardUsuario"
            android:layout_width="match_parent"
            android:layout_height="96dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@color/blanco"
            android:padding="12dp"
            android:layout_marginTop="38dp">

            <ImageView
                android:id="@+id/imgUsuario"
                android:layout_width="58dp"
                android:layout_height="58dp"
                android:src="@android:drawable/ic_menu_myplaces"
                android:contentDescription="Usuario administrador" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:id="@+id/txtNombreUsuario"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Kevin Del Bello"
                    android:textColor="@color/azul_principal"
                    android:textSize="25sp" />

                <TextView
                    android:id="@+id/txtRolUsuario"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ADMINISTRADOR"
                    android:textColor="@color/blanco"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:background="@color/verde_ok"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"
                    android:layout_marginTop="4dp" />

            </LinearLayout>

        </LinearLayout>

        <Button
            android:id="@+id/btnRegistrarCliente"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="REGISTRAR CLIENTE"
            android:textColor="@color/azul_principal"
            android:textStyle="bold"
            android:backgroundTint="@color/blanco"
            android:layout_marginTop="28dp" />

        <Button
            android:id="@+id/btnBuscarCliente"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="BUSCAR CLIENTE"
            android:textColor="@color/azul_principal"
            android:textStyle="bold"
            android:backgroundTint="@color/blanco"
            android:layout_marginTop="18dp" />

        <Button
            android:id="@+id/btnCobros"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="COBROS"
            android:textColor="@color/azul_principal"
            android:textStyle="bold"
            android:backgroundTint="@color/blanco"
            android:layout_marginTop="18dp" />

        <Button
            android:id="@+id/btnVencimientos"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="VENCIMIENTOS"
            android:textColor="@color/azul_principal"
            android:textStyle="bold"
            android:backgroundTint="@color/blanco"
            android:layout_marginTop="18dp" />

        <Button
            android:id="@+id/btnUsuarios"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="USUARIOS"
            android:textColor="@color/azul_principal"
            android:textStyle="bold"
            android:backgroundTint="@color/blanco"
            android:layout_marginTop="18dp" />

        <Button
            android:id="@+id/btnCerrarSesion"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="CERRAR SESIÓN"
            android:textColor="@color/blanco"
            android:textStyle="bold"
            android:backgroundTint="@color/rojo_alerta"
            android:layout_marginTop="28dp" />

    </LinearLayout>

</ScrollView>